{
    "editor.semanticTokenColorCustomizations": {
        "rules": {
            "class": {
                "foreground": "#4ebb81"
            },
            "interface": {
                "foreground": "#4ebb81"
            },
            "type": {
                "foreground": "#4ebb81" //"#FFCB6B"
            },
            "property": {
                "foreground": "#9dbdee"
            },
            "module": {
                "foreground": "#4ebb81",
                "fontStyle": "italic"
            },
            "namespace": {
                "foreground": "#4ebb81",
                "fontStyle": "italic"
            },
            "variable": {
                "foreground": "#7f9ef5"
            },
            "keyword": {
                "foreground": "#d36cca"
            },
            "enum": {
                "foreground": "#4ebb81"
            },
            "enumMember": "#7f9ef5",
            "comment": "#818080",
            "typeParameter": "#29ddd1"
        }
    },
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            // ╭────────────────────────────────────────────────────────────╮
            // │                          VALUES                            │ 
            // ╰────────────────────────────────────────────────────────────╯
            { // String
                "scope": [
                    "string",
                    "string.quoted.single.python",
                    // "text.tex.latex"
                ],
                "settings": {
                    "foreground": "#e6b96d"
                }
            },
            { // Quotation Marks
                "scope": [
                    "punctuation.definition.string.begin.python",
                    "punctuation.definition.string.end.python",
                    "storage.type.string.python"
                ],
                "settings": {
                    "foreground": "#b1b1b1",
                }
            },
            { // Placeholder
                "scope": [
                    "constant.character.format.placeholder.other.python"
                ],
                "settings": {
                    "foreground": "#db756a"
                }
            },
            { // Number
                "scope": [
                    "constant.numeric",
                    "constant.numeric.decimal.java",
                    "constant.numeric.glsl"
                ],
                "settings": {
                    "foreground": "#badeff",
                }
            },
            { // Boolean
                "scope": [
                    "constant.language.python",
                    "constant.language.java",
                    "constant.language.boolean",
                    "constant.language.null",
                    "constant.language.jinja"
                ],
                "settings": {
                    "foreground": "#4ebb81",
                    "fontStyle": "bold"
                }
            },
            // ╭────────────────────────────────────────────────────────────╮
            // │                        DECLARATION                         │ 
            // ╰────────────────────────────────────────────────────────────╯
            { // def, class, @
                "scope": [
                    "storage.type.function.python",
                    "storage.type.class.python",
                    "storage.modifier.java",
                    "storage.modifier.glsl",
                    "storage.type.function.lambda.python",
                    "storage.type.function.async.python",
                    "support.function.section.latex",
                    "keyword.control.label.latex",
                    "storage.modifier.declaration.python",
                    "storage.type.type.python",
                    "storage.modifier.async",
                    "storage.type.interface",
                    "storage.modifier",
                    "storage.type.function",
                    "storage.type.function",
                    "storage.type.class"
                ],
                "settings": {
                    "foreground": "#6bfffd",
                    "fontStyle": "bold"
                }
            },
            { // Controll symbols soft
                "scope": [
                    "storage.type",
                    "keyword.operator.new.js",
                    "keyword.operator.new.ts",
                    "storage.type",
                    "storage.type.property.ts",
                    "storage.type.class.jsdoc",
                    "keyword.operator.expression.void.js",
                    "keyword.operator.new",
                    "keyword.control.as.tsx",
                    "storage.modifier.declaration"
                ],
                "settings": {
                    "foreground": "#ed9d91"
                }
            },
            { // Function Parameter
                "scope": [
                    "variable.parameter",
                    "variable.parameter.function.latex",
                    "variable.language.this.js"
                ],
                "settings": {
                    "foreground": "#db936a"
                }
            },
            // ╭────────────────────────────────────────────────────────────╮
            // │                          PROGRAM                           │ 
            // ╰────────────────────────────────────────────────────────────╯
            { // import
                "scope": [
                    "keyword.control.import.python",
                    "keyword.codetag.notation.python",
                    "keyword.control.import.glsl",
                    "keyword.control.preprocessor.glsl",
                    "keyword.control.preamble.latex",
                    "keyword.control.import",
                    "keyword.operator.expression.import"
                ],
                "settings": {
                    "foreground": "#dd72cd",
                    "fontStyle": "bold"
                }
            },
            { // if, else, except, return, etc.
                "scope": [
                    "keyword",
                    "keyword.control.flow",
                    "keyword.control.glsl",
                    "keyword.control.include.latex",
                    "keyword.control.cite.latex",
                    "keyword.control.conditional",
                    "keyword.control.loop",
                    "keyword.control.flow",
                    "keyword.control.jinja",
                    "keyword.control.export",
                    "keyword.control.as",
                    "keyword.control.trycatch",
                    "keyword.control.default",
                    "keyword.control.type",
                    "keyword.control.from",
                    "keyword.operator.expression.of",
                    "keyword.operator.expression",
                    "keyword.operator.expression.typeof",
                    "keyword.operator.expression.in",
                ],
                "settings": {
                    "foreground": "#d36cca",
                }
            },
            { // Controll symbols dark
                "scope": [
                    "punctuation.separator.annotation.python",
                    "keyword.operator.bitwise.python",
                    "punctuation.section.class.begin.python",
                    "punctuation.section.function.begin.python",
                    "punctuation.separator.annotation.result.python",
                    "punctuation.separator.colon.python",
                    "constant.other.ellipsis.python",
                    "punctuation.terminator.java",
                    "punctuation.terminator.glsl",
                    "punctuation.separator.period.glsl",
                    "punctuation.separator.arguments.glsl",
                    "punctuation.terminator.statement.js",
                    "keyword.operator.type.ts",
                    "punctuation.terminator.statement.ts",
                    "punctuation.definition.template-expression.begin.js"
                ],
                "settings": {
                    "foreground": "#616161"
                }
            },
            { // Array symbols
                "scope": [
                    "punctuation.separator.arguments.python",
                    "punctuation.separator.parameters.python",
                    "punctuation.separator.dict.python",
                    "punctuation.separator.element.python",
                    "keyword.operator.unpacking.arguments.python",
                    "keyword.operator.positional.parameter.python"
                ],
                "settings": {
                    "foreground": "#D4D4D4"
                }
            },
            // ╭────────────────────────────────────────────────────────────╮
            // │                        DEVELOPMENT                         │ 
            // ╰────────────────────────────────────────────────────────────╯
            { // Docstrings & Comments
                "scope": [
                    "string.quoted.docstring.multi.python",
                    "comment.line.number-sign.python",
                    "comment.typehint.variable.notation.python",
                    "string.quoted.docstring.single.python",
                    "comment.line.double-slash.java",
                    "comment.block.javadoc.java",
                    "comment.line.double-slash.glsl",
                    "comment.block.glsl",
                    "comment.line.percentage.tex",
                    "comment.line.double-slash.typst",
                    "comment.line.double-slash",
                    "comment.block",
                    "comment.line"
                ],
                "settings": {
                    "foreground": "#818080",
                }
            },
            // ╭────────────────────────────────────────────────────────────╮
            // │                          Symbols                           │ 
            // ╰────────────────────────────────────────────────────────────╯
            { // Functions
                "scope": [
                    "entity.name.function",
                    "support.function.magic.python",
                    "keyword.operator.logical.python",
                    "storage.type.format.python",
                    "keyword.operator.logical.java",
                    "storage.type.annotation.java",
                    "entity.name.function.glsl",
                    "support.function.glsl",
                    "support.function.general.tex",
                    "keyword.operator.expression.instanceof",
                    "variable.language.super"
                ],
                "settings": {
                    "foreground": "#ebebad",
                }
            },
            { // Attribution
                "scope": [
                    "punctuation.separator.period.python",
                ],
                "settings": {
                    "foreground": "#818080"
                }
            },
            { // Arithmetic & Logic
                "scope": [
                    "keyword.operator.assignment.python",
                    "keyword.operator.comparison.python",
                    "keyword.operator.arithmetic.glsl",
                    "keyword.operator.comparison.glsl",
                    "storage.type.function.arrow",
                    "constant.language.import-export-all"
                ],
                "settings": {
                    "foreground": "#e0e0e0",
                    "fontStyle": ""
                }
            },
            { // Variables
                "scope": [
                    "variable",
                    "constant.other.caps.python",
                    "variable.other.definition.java",
                    "source.glsl",
                    "variable.language.glsl",
                    "string.interpolated.indexes.glsl",
                    "variable.language.this"
                ],
                "settings": {
                    "foreground": "#7f9ef5"
                }
            },
            { // Parameters
                "scope": [
                    "variable.parameter.function-call.python"
                ],
                "settings": {
                    "foreground": "#db756a"
                }
            },
            { // self, Specials
                "scope": [
                    "variable.parameter.function.language.special.self.python",
                    "variable.language.glsl",
                    "variable.language.this"
                ],
                "settings": {
                    "fontStyle": "italic"
                }
            },
            { // Classes
                "scope": [
                    "storage.type.java",
                    "storage.type.primitive.java",
                    "storage.type.glsl",
                    "support.class.latex",
                    "meta.include.latex",
                    "meta.citation.latex",
                    "support.type.primitive",
                    "support.type.builtin",
                    "entity.name.type",
                    "support.class.component",
                    "entity.other.inherited-class"
                ],
                "settings": {
                    "foreground": "#4ebb81",
                }
            }
        ]
    },
    "editor.bracketPairColorization.enabled": true,
    "workbench.colorCustomizations": {
        "editorBracketHighlight.foreground1": "#e9ba56",
        "editorBracketHighlight.foreground2": "#a06cdb",
        "editorBracketHighlight.foreground3": "#74d7a2",
        "editorBracketHighlight.foreground4": "#6c9fd9",
        "editorBracketHighlight.foreground5": "#d76e9f",
        "editorBracketHighlight.foreground6": "#a0d770",
        "editor.lineHighlightBackground": "#1073cf2d",
        "editor.lineHighlightBorder": "#9fced11f"
    },
}